# Environment Variables
# Copy to .env for local dev, or use .env.docker for Docker.

# === RUN MODES ===
# Local dev:  .env (this file) + run backend/frontend natively
# Docker:     docker compose --env-file .env.docker up

# --- Python ---
# Windows local: ai-pipeline/.venv/Scripts/python.exe
# Docker:        /app/ai-pipeline/.venv/bin/python3
PYTHON_PATH=ai-pipeline/.venv/Scripts/python.exe

# --- Pipeline dir ---
# Local: ai-pipeline
# Docker: /app/ai-pipeline
PIPELINE_DIR=ai-pipeline

# --- AI Pipeline ---
WHISPER_MODEL=medium
WHISPER_DEVICE=cuda
WHISPER_LANGUAGE=id

# --- External Tools ---
FFMPEG_PATH=ffmpeg
YTDLP_PATH=yt-dlp

# --- Scoring ---
NICHE_KEYWORDS=rahasia,penting,trik,solusi,tip

# --- Paths ---
DATA_DIR=data

# --- Server ---
SERVER_PORT=8080
FRONTEND_URL=http://localhost:3000
